{
  "promptId": "d8-seo-lead-report",
  "name": "B2B SEO 增长与询盘质量报告",
  "nameEn": "B2B SEO Growth and Lead Quality Report",
  "category": "s14_monitoring",
  "version": "1.0",
  "requiresHumanReview": true,
  "canCreateTasks": false,
  "canWriteWordPress": false,
  "targetAgent": "external",
  "workflowStepId": "monitoring",
  "inputSchema": {
    "type": "object",
    "properties": {
      "websiteDomain": {
        "type": "string",
        "description": "网站域名"
      },
      "dataPeriod": {
        "type": "string",
        "description": "数据周期，例如 2026-xx-xx 至 2026-xx-xx"
      },
      "targetMarket": {
        "type": "string",
        "description": "目标市场"
      },
      "primaryConversionGoal": {
        "type": "string",
        "enum": ["RFQ", "Contact", "WhatsApp", "Catalog", "Sample"],
        "description": "主转化目标"
      },
      "gscData": {
        "type": "string",
        "description": "GSC 数据：页面、查询词、曝光、点击、CTR、平均排名（粘贴）"
      },
      "ga4GtmData": {
        "type": "string",
        "description": "GA4/GTM 数据：入口页、事件、国家、设备、转化（粘贴）"
      },
      "leadTrackingData": {
        "type": "string",
        "description": "Lead Tracking 数据：询盘数量、国家、产品、数量、来源页面、质量等级、跟进状态（粘贴）"
      },
      "newOrModifiedPagesThisWeek": {
        "type": "string",
        "description": "本周新增/修改页面（粘贴）"
      }
    },
    "required": [
      "websiteDomain",
      "dataPeriod",
      "targetMarket",
      "primaryConversionGoal",
      "gscData",
      "ga4GtmData",
      "leadTrackingData"
    ]
  },
  "outputSchema": {
    "schemaName": "d8_seo_lead_report_v1",
    "type": "object",
    "properties": {
      "weeklyConclusion": {
        "type": "string",
        "description": "本周结论（150字内）"
      },
      "seoDataAnalysis": {
        "type": "object",
        "description": "SEO 数据分析",
        "properties": {
          "impressionGrowthPages": { "type": "array" },
          "clickGrowthPages": { "type": "array" },
          "lowCTRPages": { "type": "array" },
          "ranking8to20Opportunities": { "type": "array" },
          "unindexedOrAbnormalPages": { "type": "array" },
          "specificActions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "leadDataAnalysis": {
        "type": "object",
        "description": "Lead 数据分析",
        "properties": {
          "totalInquiries": { "type": "number" },
          "effectiveInquiryRate": { "type": "string" },
          "countryDistribution": { "type": "object" },
          "productLineDistribution": { "type": "object" },
          "sourcePageAnalysis": { "type": "array" },
          "lowQualityReasons": { "type": "array", "items": { "type": "string" } }
        }
      },
      "keywordToInquiryPath": {
        "type": "array",
        "description": "关键词到询盘路径分析",
        "items": {
          "type": "object",
          "properties": {
            "keyword": { "type": "string" },
            "impressions": { "type": "number" },
            "clicks": { "type": "number" },
            "inquiriesGenerated": { "type": "number" },
            "verdict": { "type": "string" }
          }
        }
      },
      "pageOptimizationList": {
        "type": "array",
        "description": "页面优化清单",
        "items": {
          "type": "object",
          "properties": {
            "page": { "type": "string" },
            "problem": { "type": "string" },
            "dataEvidence": { "type": "string" },
            "fixSuggestion": { "type": "string" },
            "expectedImpact": { "type": "string" },
            "priority": { "type": "string", "enum": ["immediate", "important", "observe"] }
          }
        }
      },
      "newContentSuggestions": {
        "type": "array",
        "description": "内容新增建议（5-10个）",
        "items": {
          "type": "object",
          "properties": {
            "targetKeyword": { "type": "string" },
            "pageType": { "type": "string" },
            "relatedCommercialPage": { "type": "string" },
            "cta": { "type": "string" }
          }
        }
      },
      "trackingIssues": {
        "type": "array",
        "description": "转化追踪问题",
        "items": { "type": "string" }
      },
      "nextWeekActions": {
        "type": "array",
        "description": "下周行动清单（10条）",
        "items": {
          "type": "object",
          "properties": {
            "task": { "type": "string" },
            "responsiblePerson": { "type": "string" },
            "priority": { "type": "string" },
            "estimatedTime": { "type": "string" }
          }
        }
      }
    },
    "required": [
      "weeklyConclusion",
      "seoDataAnalysis",
      "leadDataAnalysis",
      "keywordToInquiryPath",
      "pageOptimizationList",
      "newContentSuggestions",
      "trackingIssues",
      "nextWeekActions"
    ]
  },
  "forbiddenActions": [
    "不要只汇报数据，要给操作建议",
    "不要把曝光增长等同于成功",
    "所有建议都要围绕有效询盘和采购决策"
  ],
  "humanChecklist": [
    "确认本周结论是否准确反映数据趋势",
    "验证有效询盘率计算是否正确",
    "检查关键词到询盘路径是否完整",
    "核实页面优化清单是否按优先级排列",
    "确认下周行动清单是否可执行且有明确负责人"
  ],
  "markdownTemplate": "# d8-seo-lead-report\n\n# 角色定义\n你是一名 B2B SEO 增长分析师和询盘质量分析师。\n你的任务是基于 GSC、GA4、GTM 和线索表数据，判断网站是否在产生真正有价值的 B2B 询盘，并输出具体优化动作。\n\n# 输入信息\n网站域名：【填写】\n数据周期：【填写，例如 2026-xx-xx 至 2026-xx-xx】\n目标市场：【填写】\n主转化目标：【RFQ/Contact/WhatsApp/Catalog/Sample】\nGSC 数据：【粘贴：页面、查询词、曝光、点击、CTR、平均排名】\nGA4/GTM 数据：【粘贴：入口页、事件、国家、设备、转化】\nLead Tracking 数据：【粘贴：询盘数量、国家、产品、数量、来源页面、质量等级、跟进状态】\n本周新增/修改页面：【粘贴】\n\n# 输出结构\n\n## 一、本周结论\n用 150 字以内说明：流量是否增长、是否带来有效询盘、最大问题是什么。\n\n## 二、SEO 数据分析\n分析：曝光增长页、点击增长页、CTR 低页、排名 8-20 名机会页、未收录/异常页。\n输出具体动作。\n\n## 三、Lead 数据分析\n分析：询盘数量、有效询盘率、国家分布、产品线分布、来源页面、低质询盘原因。\n判断哪些页面真正有商业价值。\n\n## 四、关键词到询盘路径分析\n把高曝光查询词、高点击页面和实际询盘来源对应起来。\n指出：哪些关键词只带流量不带询盘，哪些关键词值得加码。\n\n## 五、页面优化清单\n按 🔴立即 / 🟠重要 / 🟡观察 输出页面级优化建议。\n字段：页面 / 问题 / 数据依据 / 修改建议 / 预期影响。\n\n## 六、内容新增建议\n输出下周应新增的 5-10 个页面或文章，说明目标关键词、页面类型、对应商业页和 CTA。\n\n## 七、转化追踪问题\n检查是否有表单事件漏记、WhatsApp 点击未追踪、Catalog 下载未追踪、来源页面缺失等问题。\n\n## 八、下周行动清单\n输出 10 条可执行任务，包含负责人建议、优先级和预计耗时。\n\n# 输出规范\n- 不要只汇报数据，要给操作建议。\n- 不要把曝光增长等同于成功。\n- 所有建议都要围绕有效询盘和采购决策。",
  "downstreamStages": ["s14_monitoring"],
